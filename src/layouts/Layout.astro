---
import { ClientRouter } from 'astro:transitions';
import AgentationToolbar from '../components/AgentationToolbar';
import EntryExplorer from '@/components/EntryExplorer';
import { getAllPreviews } from '@/lib/content';
import { withBase } from '@/lib/paths';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	active?: 'home' | 'library' | 'inbox' | 'system';
	selectedHref?: string;
}

const {
	title = 'Diary',
	description = 'Eine ruhige Bibliothek aus Notizen, Erkenntnissen, Projektideen und rohen Gedanken.',
	active = 'home',
	selectedHref,
} = Astro.props;

const pageTitle = title === 'Diary' ? title : `${title} · Diary`;
const entries = await getAllPreviews();
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<ClientRouter />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<link rel="icon" href={withBase('/favicon.ico')} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<div class="mx-auto grid min-h-screen w-full max-w-[112rem] gap-8 px-4 pt-7 pb-5 sm:px-6 sm:pt-8 sm:pb-6 lg:grid-cols-[17rem_minmax(0,1fr)] lg:gap-12 lg:px-8 lg:pt-10">
			<EntryExplorer
				client:load
				transition:persist="diary-explorer"
				entries={entries}
				selectedHref={selectedHref}
				active={active}
			/>

			<div class="reader-shell min-w-0 lg:border-l lg:pl-12">
				<div class="reader-frame relative min-h-[60svh] w-full">
					<div aria-hidden="true" class="reader-loading">
						<div class="reader-loading-lines">
							<span class="reader-loading-line reader-loading-line-sm"></span>
							<span class="reader-loading-line reader-loading-line-lg"></span>
							<span class="reader-loading-line reader-loading-line-md"></span>
							<span class="reader-loading-line reader-loading-line-xs"></span>
						</div>
					</div>

					<main id="reader-root" class="reader-stage w-full py-4 lg:pt-8 lg:pb-5">
						<slot />
					</main>
				</div>
			</div>
		</div>

		<AgentationToolbar client:only="react" />

		<script is:inline>
			if (!window.__diaryReaderLoadingBound) {
				window.__diaryReaderLoadingBound = true;

				const showLoading = (target = document) => {
					target.documentElement.setAttribute('data-reader-loading', 'true');
				};

				const hideLoading = (target = document) => {
					target.documentElement.removeAttribute('data-reader-loading');
				};

				document.addEventListener('astro:before-preparation', () => {
					showLoading(document);
				});

				document.addEventListener('astro:before-swap', (event) => {
					showLoading(event.newDocument);
				});

				document.addEventListener('astro:page-load', () => {
					hideLoading(document);
				});
			}
		</script>
	</body>
</html>
