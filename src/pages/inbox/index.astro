---
import { render } from 'astro:content';
import EntryReader from '@/components/EntryReader.astro';
import Layout from '../../layouts/Layout.astro';
import { getLatestEntryRecord } from '@/lib/content';
import { withBase } from '@/lib/paths';

const latest = await getLatestEntryRecord('inbox');

if (!latest) {
	throw new Error('Inbox benötigt mindestens einen Eintrag.');
}

const { Content } = await render(latest.entry);
const selectedHref = withBase(`/inbox/${latest.entry.id}/`);
---

<Layout
	title={latest.entry.data.title}
	description={latest.entry.data.summary}
	active="inbox"
	selectedHref={selectedHref}
>
	<EntryReader
		bucket="inbox"
		kind={latest.entry.data.kind}
		title={latest.entry.data.title}
		summary={latest.entry.data.summary}
		created={latest.entry.data.created}
		tags={latest.entry.data.tags}
	>
		<Content />
	</EntryReader>
</Layout>
