---
import { Separator } from '@/components/ui/separator';
import EntryRow from '../../components/EntryRow.astro';
import Layout from '../../layouts/Layout.astro';
import { getInboxPreviews } from '../../lib/content';
import { inboxKindLabels } from '../../lib/taxonomy';

const entries = await getInboxPreviews();

const sections = (['spark', 'fragment', 'question', 'seed'] as const)
	.map((kind) => ({
		kind,
		label: inboxKindLabels[kind],
		items: entries.filter((entry) => entry.kind === kind),
	}))
	.filter((section) => section.items.length > 0);
---

<Layout
	title="Inbox"
	description="Rohes Material, frühe Gedanken, Fragen und halbe Funde."
	active="inbox"
>
	<header class="space-y-1">
		<p class="text-[11px] uppercase tracking-[0.2em] text-muted-foreground">Inbox</p>
		<h1 class="text-lg font-medium tracking-tight text-foreground">Rohmaterial</h1>
		<p class="max-w-2xl text-sm leading-6 text-muted-foreground">
			Gedanken, Fragen und Fragmente, die noch keine fertige Form brauchen.
		</p>
	</header>

	<Separator />

	<div class="space-y-8">
		{
			sections.map((section) => (
				<section class="space-y-3">
					<div class="space-y-1">
						<p class="text-[11px] uppercase tracking-[0.2em] text-muted-foreground">
							{section.label}
						</p>
					</div>

					<div class="divide-y">
						{
							section.items.map((entry) => (
								<EntryRow
									href={entry.href}
									title={entry.title}
									summary={entry.summary}
									date={entry.created}
									bucket={entry.bucket}
									kind={entry.kind}
								/>
							))
						}
					</div>
				</section>
			))
		}
	</div>
</Layout>
