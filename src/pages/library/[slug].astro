---
import { Badge } from '@/components/ui/badge';
import { buttonVariants } from '@/components/ui/button';
import { Separator } from '@/components/ui/separator';
import { withBase } from '@/lib/paths';
import { cn } from '@/lib/utils';
import { getCollection, render } from 'astro:content';
import EntryRow from '../../components/EntryRow.astro';
import Layout from '../../layouts/Layout.astro';
import { formatLongDate } from '../../lib/date';
import { getLibraryPreviews } from '../../lib/content';
import { bucketLabels, getKindLabel } from '../../lib/taxonomy';

export async function getStaticPaths() {
	const entries = await getCollection('library');
	return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const allEntries = await getLibraryPreviews();

const related = allEntries
	.filter((candidate) => candidate.slug !== entry.id)
	.filter((candidate) => candidate.tags.some((tag) => entry.data.tags.includes(tag)))
	.slice(0, 3);
---

<Layout title={entry.data.title} description={entry.data.summary} active="library">
	<article class="space-y-6">
		<a
			href={withBase('/library/')}
			class={cn(buttonVariants({ variant: 'ghost', size: 'sm' }), 'w-fit rounded-md px-0 text-muted-foreground')}
		>
			Zurück zur Bibliothek
		</a>

		<header class="space-y-4">
			<div class="flex flex-wrap items-center gap-2">
				<Badge variant="outline" className="rounded-md px-1.5 py-0 text-[10px] uppercase tracking-[0.18em] text-muted-foreground">
					{bucketLabels.library}
				</Badge>
				<Badge variant="secondary" className="rounded-md px-1.5 py-0 text-[10px] text-muted-foreground">
					{getKindLabel('library', entry.data.kind)}
				</Badge>
				<span class="text-xs text-muted-foreground">{formatLongDate(entry.data.created)}</span>
			</div>

			<div class="space-y-2">
				<h1 class="max-w-3xl text-2xl font-medium tracking-tight text-foreground sm:text-3xl">
					{entry.data.title}
				</h1>
				<p class="max-w-2xl text-sm leading-6 text-muted-foreground">{entry.data.summary}</p>
			</div>

			<div class="flex flex-wrap gap-2">
				{entry.data.tags.map((tag) => <Badge variant="outline" className="rounded-md px-1.5 py-0 text-[10px] text-muted-foreground">#{tag}</Badge>)}
			</div>
		</header>

		<Separator />

		<div class="prose-copy">
			<Content />
		</div>
	</article>

	{
		related.length > 0 && (
			<section class="space-y-4">
				<div class="space-y-1">
					<p class="text-[11px] uppercase tracking-[0.2em] text-muted-foreground">Verwandt</p>
					<h2 class="text-base font-medium tracking-tight text-foreground">Mehr aus derselben Gegend</h2>
				</div>

				<Separator />

				<div class="divide-y">
					{
						related.map((item) => (
							<EntryRow
								href={item.href}
								title={item.title}
								summary={item.summary}
								date={item.created}
								bucket={item.bucket}
								kind={item.kind}
							/>
						))
					}
				</div>
			</section>
		)
	}
</Layout>
