---
import { Separator } from '@/components/ui/separator';
import EntryRow from '../../components/EntryRow.astro';
import Layout from '../../layouts/Layout.astro';
import { getLibraryPreviews } from '../../lib/content';
import { libraryKindLabels } from '../../lib/taxonomy';

const entries = await getLibraryPreviews();

const sections = (['insight', 'idea', 'life', 'journal'] as const)
	.map((kind) => ({
		kind,
		label: libraryKindLabels[kind],
		items: entries.filter((entry) => entry.kind === kind),
	}))
	.filter((section) => section.items.length > 0);
---

<Layout
	title="Bibliothek"
	description="Sortierte Einträge, Erkenntnisse, Projektgedanken und längere Notizen."
	active="library"
>
	<header class="space-y-1">
		<p class="text-[11px] uppercase tracking-[0.2em] text-muted-foreground">Bibliothek</p>
		<h1 class="text-lg font-medium tracking-tight text-foreground">Lesbare Stücke</h1>
		<p class="max-w-2xl text-sm leading-6 text-muted-foreground">
			Einträge, die schon genug Form haben, um wiedergefunden zu werden.
		</p>
	</header>

	<Separator />

	<div class="space-y-8">
		{
			sections.map((section) => (
				<section class="space-y-3">
					<div class="space-y-1">
						<p class="text-[11px] uppercase tracking-[0.2em] text-muted-foreground">
							{section.label}
						</p>
					</div>

					<div class="divide-y">
						{
							section.items.map((entry) => (
								<EntryRow
									href={entry.href}
									title={entry.title}
									summary={entry.summary}
									date={entry.created}
									bucket={entry.bucket}
									kind={entry.kind}
								/>
							))
						}
					</div>
				</section>
			))
		}
	</div>
</Layout>
