---
import { render } from 'astro:content';
import EntryReader from '@/components/EntryReader.astro';
import Layout from '../layouts/Layout.astro';
import { getLatestEntryRecord } from '@/lib/content';
import { withBase } from '@/lib/paths';

const latest = await getLatestEntryRecord();

if (!latest) {
	throw new Error('Diary benötigt mindestens einen Eintrag.');
}

const { Content } = await render(latest.entry);
const selectedHref = withBase(`/${latest.bucket}/${latest.entry.id}/`);
---

<Layout
	title={latest.entry.data.title}
	description={latest.entry.data.summary}
	active="home"
	selectedHref={selectedHref}
>
	<EntryReader title={latest.entry.data.title} summary={latest.entry.data.summary}>
		<Content />
	</EntryReader>
</Layout>
